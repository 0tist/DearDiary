{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DearDiary",
  "version": "0.1.0",
  "identifier": "com.deardiary.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DearDiary",
        "width": 480,
        "height": 360,
        "minWidth": 360,
        "minHeight": 240,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "fullscreen": false,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Capture diary entries; Claude routes them.",
    "longDescription": "Always-open compose window. Type a thought, hit Save, and the local diary-process.sh job (every 15 min, or on-demand via the Process Now button) hands the inbox to a headless Claude run that files each entry under ~/DearDiary/diary/."
  }
}
